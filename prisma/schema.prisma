generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Area {
  id        Int         @id @default(autoincrement())
  name      String      @unique(map: "Area_name_key")
  adminId   Int?
  createdAt DateTime    @default(now())
  updatedAt DateTime
  user      User?       @relation(fields: [adminId], references: [id], map: "Area_adminId_fkey")
  pop       Pop[]
  warehouse Warehouse[]

  @@index([adminId], map: "Area_adminId_idx")
  @@map("area")
}

model Category {
  id        Int        @id @default(autoincrement())
  name      String
  code      String?
  companyId Int?
  createdAt DateTime   @default(now())
  updatedAt DateTime
  company   Company?   @relation(fields: [companyId], references: [id], map: "Category_companyId_fkey")
  item      Item[]
  stockin   StockIn[]
  stockout  StockOut[]

  @@index([companyId], map: "Category_companyId_idx")
  @@map("category")
}

model Company {
  id           Int            @id @default(autoincrement())
  name         String
  brand        String?
  address      String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime
  category     Category[]
  item         Item[]
  stockin      StockIn[]
  stockout     StockOut[]
  stockrequest StockRequest[]

  @@map("company")
}

model CustomerInstallation {
  id              Int            @id @default(autoincrement())
  customerName    String
  customerAddress String?
  itemId          Int
  serialNumberId  Int?
  installedBy     String?
  installedAt     DateTime       @default(now())
  description     String?
  item            Item           @relation(fields: [itemId], references: [id], map: "CustomerInstallation_itemId_fkey")
  serialnumber    SerialNumber?  @relation(fields: [serialNumberId], references: [id], map: "CustomerInstallation_serialNumberId_fkey")

  @@index([itemId], map: "CustomerInstallation_itemId_idx")
  @@index([serialNumberId], map: "CustomerInstallation_serialNumberId_idx")
  @@map("customerinstallation")
}

model DamagedItem {
  id            Int             @id @default(autoincrement())
  warehouseId   Int
  itemId        Int
  typeId        Int?
  qty           Int
  description   String?
  locationFrom  String?
  createdAt     DateTime        @default(now())
  item          Item            @relation(fields: [itemId], references: [id], map: "DamagedItem_itemId_fkey")
  itemtype      ItemType?       @relation(fields: [typeId], references: [id], map: "DamagedItem_typeId_fkey")
  warehouse     Warehouse       @relation(fields: [warehouseId], references: [id], map: "DamagedItem_warehouseId_fkey")
  damagedserial DamagedSerial[]

  @@index([itemId], map: "DamagedItem_itemId_idx")
  @@index([typeId], map: "DamagedItem_typeId_fkey")
  @@index([warehouseId], map: "DamagedItem_warehouseId_idx")
  @@map("damageditem")
}

model DamagedSerial {
  id             Int          @id @default(autoincrement())
  damagedItemId  Int
  serialNumberId Int
  serialCode     String
  damageditem    DamagedItem  @relation(fields: [damagedItemId], references: [id], onDelete: Cascade, map: "DamagedSerial_damagedItemId_fkey")
  serialnumber   SerialNumber @relation(fields: [serialNumberId], references: [id], map: "DamagedSerial_serialNumberId_fkey")

  @@index([damagedItemId], map: "DamagedSerial_damagedItemId_idx")
  @@index([serialNumberId], map: "DamagedSerial_serialNumberId_idx")
  @@map("damagedserial")
}

model Distributor {
  id            Int             @id @default(autoincrement())
  vendorName    String
  company       String?
  address       String?
  email         String?
  phone         String?
  mobile        String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime
  purchaseorder PurchaseOrder[]
  stockin       StockIn[]

  @@map("distributor")
}

model Item {
  id                   Int                    @id @default(autoincrement())
  code                 String                 @unique(map: "Item_code_key")
  name                 String
  hasSN                Boolean                @default(true)
  minStock             Int                    @default(0)
  unit                 String                 @default("Pcs")
  price                Float                  @default(0)
  companyId            Int?
  categoryId           Int?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime
  customerinstallation CustomerInstallation[]
  damageditem          DamagedItem[]
  category             Category?              @relation(fields: [categoryId], references: [id], map: "Item_categoryId_fkey")
  company              Company?               @relation(fields: [companyId], references: [id], map: "Item_companyId_fkey")
  popinstallation      PopInstallation[]
  purchaseorderitem    PurchaseOrderItem[]
  serialnumber         SerialNumber[]
  stockin              StockIn[]
  stockout             StockOut[]
  stockrequestdetail   StockRequestDetail[]
  stocktransfer        StockTransfer[]
  warehousestock       WarehouseStock[]

  @@index([categoryId], map: "Item_categoryId_idx")
  @@index([companyId], map: "Item_companyId_idx")
  @@map("item")
}

model ItemStatus {
  id           Int            @id @default(autoincrement())
  name         String         @unique(map: "ItemStatus_name_key")
  serialnumber SerialNumber[]

  @@map("itemstatus")
}

model ItemType {
  id           Int            @id @default(autoincrement())
  name         String         @unique(map: "ItemType_name_key")
  damageditem  DamagedItem[]
  serialnumber SerialNumber[]
  stockin      StockIn[]
  stockout     StockOut[]

  @@map("itemtype")
}

model Pop {
  id              Int               @id @default(autoincrement())
  name            String
  location        String?
  areaId          Int?
  warehouseId     Int?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  area            Area?             @relation(fields: [areaId], references: [id], map: "Pop_areaId_fkey")
  warehouse       Warehouse?        @relation(fields: [warehouseId], references: [id], map: "Pop_warehouseId_fkey")
  popinstallation PopInstallation[]
  serialnumber    SerialNumber[]
  stockout        StockOut[]

  @@index([areaId], map: "Pop_areaId_idx")
  @@index([warehouseId], map: "Pop_warehouseId_idx")
  @@map("pop")
}

model PopInstallation {
  id             Int           @id @default(autoincrement())
  popId          Int
  itemId         Int
  serialNumberId Int?
  installedBy    String?
  installedAt    DateTime      @default(now())
  description    String?
  item           Item          @relation(fields: [itemId], references: [id], map: "PopInstallation_itemId_fkey")
  pop            Pop           @relation(fields: [popId], references: [id], map: "PopInstallation_popId_fkey")
  serialnumber   SerialNumber? @relation(fields: [serialNumberId], references: [id], map: "PopInstallation_serialNumberId_fkey")

  @@index([itemId], map: "PopInstallation_itemId_idx")
  @@index([popId], map: "PopInstallation_popId_idx")
  @@index([serialNumberId], map: "PopInstallation_serialNumberId_idx")
  @@map("popinstallation")
}

model PurchaseOrder {
  id                Int                 @id @default(autoincrement())
  distributorId     Int
  code              String              @unique(map: "PurchaseOrder_code_key")
  recipient         String?
  discount          Float               @default(0)
  tax               Float               @default(0)
  date              DateTime            @default(now())
  createdAt         DateTime            @default(now())
  updatedAt         DateTime
  distributor       Distributor         @relation(fields: [distributorId], references: [id], map: "PurchaseOrder_distributorId_fkey")
  purchaseorderitem PurchaseOrderItem[]

  @@index([distributorId], map: "PurchaseOrder_distributorId_idx")
  @@map("purchaseorder")
}

model PurchaseOrderItem {
  id            Int                        @id @default(autoincrement())
  poId          Int
  itemId        Int
  qty           Int
  price         Float
  total         Float
  currency      purchaseorderitem_currency @default(IDR)
  item          Item                       @relation(fields: [itemId], references: [id], map: "PurchaseOrderItem_itemId_fkey")
  purchaseorder PurchaseOrder              @relation(fields: [poId], references: [id], onDelete: Cascade, map: "PurchaseOrderItem_poId_fkey")

  @@index([itemId], map: "PurchaseOrderItem_itemId_idx")
  @@index([poId], map: "PurchaseOrderItem_poId_idx")
  @@map("purchaseorderitem")
}

model SerialNumber {
  id                   Int                    @id @default(autoincrement())
  code                 String                 @unique(map: "SerialNumber_code_key")
  price                Float                  @default(0)
  itemId               Int
  typeId               Int
  statusId             Int
  warehouseId          Int?
  popId                Int?
  customerId           Int?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime
  customerinstallation CustomerInstallation[]
  damagedserial        DamagedSerial[]
  popinstallation      PopInstallation[]
  item                 Item                   @relation(fields: [itemId], references: [id], map: "SerialNumber_itemId_fkey")
  pop                  Pop?                   @relation(fields: [popId], references: [id], map: "SerialNumber_popId_fkey")
  itemstatus           ItemStatus             @relation(fields: [statusId], references: [id], map: "SerialNumber_statusId_fkey")
  itemtype             ItemType               @relation(fields: [typeId], references: [id], map: "SerialNumber_typeId_fkey")
  warehouse            Warehouse?             @relation(fields: [warehouseId], references: [id], map: "SerialNumber_warehouseId_fkey")
  stockinserial        StockInSerial[]
  stockoutserial       StockOutSerial[]

  @@index([itemId], map: "SerialNumber_itemId_idx")
  @@index([popId], map: "SerialNumber_popId_idx")
  @@index([statusId], map: "SerialNumber_statusId_idx")
  @@index([typeId], map: "SerialNumber_typeId_idx")
  @@index([warehouseId], map: "SerialNumber_warehouseId_idx")
  @@map("serialnumber")
}

model StockIn {
  id            Int             @id @default(autoincrement())
  warehouseId   Int
  itemId        Int
  companyId     Int?
  categoryId    Int?
  typeId        Int?
  distributorId Int?
  qty           Int
  price         Float           @default(0)
  totalPrice    Float           @default(0)
  clientName    String?
  description   String?
  adminId       Int?
  createdAt     DateTime        @default(now())
  category      Category?       @relation(fields: [categoryId], references: [id], map: "StockIn_categoryId_fkey")
  company       Company?        @relation(fields: [companyId], references: [id], map: "StockIn_companyId_fkey")
  distributor   Distributor?    @relation(fields: [distributorId], references: [id], map: "StockIn_distributorId_fkey")
  item          Item            @relation(fields: [itemId], references: [id], map: "StockIn_itemId_fkey")
  itemtype      ItemType?       @relation(fields: [typeId], references: [id], map: "StockIn_typeId_fkey")
  warehouse     Warehouse       @relation(fields: [warehouseId], references: [id], map: "StockIn_warehouseId_fkey")
  stockinserial StockInSerial[]

  @@index([categoryId], map: "StockIn_categoryId_fkey")
  @@index([companyId], map: "StockIn_companyId_fkey")
  @@index([distributorId], map: "StockIn_distributorId_fkey")
  @@index([itemId], map: "StockIn_itemId_idx")
  @@index([typeId], map: "StockIn_typeId_fkey")
  @@index([warehouseId], map: "StockIn_warehouseId_idx")
  @@map("stockin")
}

model StockInSerial {
  id             Int          @id @default(autoincrement())
  stockInId      Int
  serialNumberId Int
  serialCode     String
  serialnumber   SerialNumber @relation(fields: [serialNumberId], references: [id], map: "StockInSerial_serialNumberId_fkey")
  stockin        StockIn      @relation(fields: [stockInId], references: [id], onDelete: Cascade, map: "StockInSerial_stockInId_fkey")

  @@index([serialNumberId], map: "StockInSerial_serialNumberId_idx")
  @@index([stockInId], map: "StockInSerial_stockInId_idx")
  @@map("stockinserial")
}

model StockOut {
  id                                              Int              @id @default(autoincrement())
  outType                                         stockout_outType
  warehouseId                                     Int
  itemId                                          Int
  companyId                                       Int?
  categoryId                                      Int?
  typeId                                          Int?
  targetWarehouseId                               Int?
  popId                                           Int?
  customerName                                    String?
  qty                                             Int
  techName1                                       String?
  techName2                                       String?
  description                                     String?
  location                                        String?
  createdAt                                       DateTime         @default(now())
  category                                        Category?        @relation(fields: [categoryId], references: [id], map: "StockOut_categoryId_fkey")
  company                                         Company?         @relation(fields: [companyId], references: [id], map: "StockOut_companyId_fkey")
  item                                            Item             @relation(fields: [itemId], references: [id], map: "StockOut_itemId_fkey")
  pop                                             Pop?             @relation(fields: [popId], references: [id], map: "StockOut_popId_fkey")
  warehouse_stockout_targetWarehouseIdTowarehouse Warehouse?       @relation("stockout_targetWarehouseIdTowarehouse", fields: [targetWarehouseId], references: [id], map: "StockOut_targetWarehouseId_fkey")
  itemtype                                        ItemType?        @relation(fields: [typeId], references: [id], map: "StockOut_typeId_fkey")
  warehouse_stockout_warehouseIdTowarehouse       Warehouse        @relation("stockout_warehouseIdTowarehouse", fields: [warehouseId], references: [id], map: "StockOut_warehouseId_fkey")
  stockoutserial                                  StockOutSerial[]

  @@index([categoryId], map: "StockOut_categoryId_fkey")
  @@index([companyId], map: "StockOut_companyId_fkey")
  @@index([itemId], map: "StockOut_itemId_idx")
  @@index([popId], map: "StockOut_popId_idx")
  @@index([targetWarehouseId], map: "StockOut_targetWarehouseId_idx")
  @@index([typeId], map: "StockOut_typeId_fkey")
  @@index([warehouseId], map: "StockOut_warehouseId_idx")
  @@map("stockout")
}

model StockOutSerial {
  id             Int          @id @default(autoincrement())
  stockOutId     Int
  serialNumberId Int
  serialCode     String
  serialnumber   SerialNumber @relation(fields: [serialNumberId], references: [id], map: "StockOutSerial_serialNumberId_fkey")
  stockout       StockOut     @relation(fields: [stockOutId], references: [id], onDelete: Cascade, map: "StockOutSerial_stockOutId_fkey")

  @@index([serialNumberId], map: "StockOutSerial_serialNumberId_idx")
  @@index([stockOutId], map: "StockOutSerial_stockOutId_idx")
  @@map("stockoutserial")
}

model StockRequest {
  id                 Int                  @id @default(autoincrement())
  companyId          Int?
  warehouseId        Int
  description        String?
  status             String?
  createdBy          Int?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime
  company            Company?             @relation(fields: [companyId], references: [id], map: "StockRequest_companyId_fkey")
  warehouse          Warehouse            @relation(fields: [warehouseId], references: [id], map: "StockRequest_warehouseId_fkey")
  stockrequestdetail StockRequestDetail[]

  @@index([companyId], map: "StockRequest_companyId_idx")
  @@index([warehouseId], map: "StockRequest_warehouseId_idx")
  @@map("stockrequest")
}

model StockRequestDetail {
  id           Int          @id @default(autoincrement())
  requestId    Int
  itemId       Int
  qty          Int
  unit         String?
  item         Item         @relation(fields: [itemId], references: [id], map: "StockRequestDetail_itemId_fkey")
  stockrequest StockRequest @relation(fields: [requestId], references: [id], onDelete: Cascade, map: "StockRequestDetail_requestId_fkey")

  @@index([itemId], map: "StockRequestDetail_itemId_idx")
  @@index([requestId], map: "StockRequestDetail_requestId_idx")
  @@map("stockrequestdetail")
}

model StockTransfer {
  id                                                 Int                  @id @default(autoincrement())
  fromWarehouseId                                    Int
  toWarehouseId                                      Int
  itemId                                             Int
  qty                                                Int
  status                                             stocktransfer_status @default(PENDING)
  createdBy                                          Int?
  createdAt                                          DateTime             @default(now())
  updatedAt                                          DateTime
  warehouse_stocktransfer_fromWarehouseIdTowarehouse Warehouse            @relation("stocktransfer_fromWarehouseIdTowarehouse", fields: [fromWarehouseId], references: [id], map: "StockTransfer_fromWarehouseId_fkey")
  item                                               Item                 @relation(fields: [itemId], references: [id], map: "StockTransfer_itemId_fkey")
  warehouse_stocktransfer_toWarehouseIdTowarehouse   Warehouse            @relation("stocktransfer_toWarehouseIdTowarehouse", fields: [toWarehouseId], references: [id], map: "StockTransfer_toWarehouseId_fkey")

  @@index([fromWarehouseId], map: "StockTransfer_fromWarehouseId_idx")
  @@index([itemId], map: "StockTransfer_itemId_idx")
  @@index([toWarehouseId], map: "StockTransfer_toWarehouseId_fkey")
  @@map("stocktransfer")
}

model User {
  id          Int        @id @default(autoincrement())
  username    String     @unique(map: "User_username_key")
  password    String
  name        String
  phone       String?
  level       user_level @default(STAFF)
  jabatan     String?
  isActive    Boolean    @default(true)
  warehouseId Int?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime
  area        Area[]
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id], map: "User_warehouseId_fkey")

  @@index([warehouseId], map: "User_warehouseId_idx")
  @@map("user")
}

model Warehouse {
  id                                                     Int              @id @default(autoincrement())
  name                                                   String
  location                                               String?
  type                                                   warehouse_type   @default(CABANG)
  areaId                                                 Int?
  createdAt                                              DateTime         @default(now())
  updatedAt                                              DateTime
  damageditem                                            DamagedItem[]
  pop                                                    Pop[]
  serialnumber                                           SerialNumber[]
  stockin                                                StockIn[]
  stockout_stockout_targetWarehouseIdTowarehouse         StockOut[]       @relation("stockout_targetWarehouseIdTowarehouse")
  stockout_stockout_warehouseIdTowarehouse               StockOut[]       @relation("stockout_warehouseIdTowarehouse")
  stockrequest                                           StockRequest[]
  stocktransfer_stocktransfer_fromWarehouseIdTowarehouse StockTransfer[]  @relation("stocktransfer_fromWarehouseIdTowarehouse")
  stocktransfer_stocktransfer_toWarehouseIdTowarehouse   StockTransfer[]  @relation("stocktransfer_toWarehouseIdTowarehouse")
  user                                                   User[]
  area                                                   Area?            @relation(fields: [areaId], references: [id], map: "Warehouse_areaId_fkey")
  warehousestock                                         WarehouseStock[]

  @@index([areaId], map: "Warehouse_areaId_idx")
  @@map("warehouse")
}

model WarehouseStock {
  id             Int       @id @default(autoincrement())
  itemId         Int
  warehouseId    Int
  stockNew       Int       @default(0)
  stockDismantle Int       @default(0)
  stockDamaged   Int       @default(0)
  minStock       Int       @default(0)
  updatedAt      DateTime
  item           Item      @relation(fields: [itemId], references: [id], map: "WarehouseStock_itemId_fkey")
  warehouse      Warehouse @relation(fields: [warehouseId], references: [id], map: "WarehouseStock_warehouseId_fkey")

  @@unique([itemId, warehouseId], map: "WarehouseStock_itemId_warehouseId_key")
  @@index([warehouseId], map: "WarehouseStock_warehouseId_idx")
  @@map("warehousestock")
}

enum stockout_outType {
  TRANSFER
  POP_INSTALL
  CUSTOMER_INSTALL
}

enum warehouse_type {
  PUSAT
  CABANG
}

enum stocktransfer_status {
  PENDING
  SHIPPED
  RECEIVED
}

enum user_level {
  MASTER
  CABANG
  SPV
  STAFF
  USER
}

enum purchaseorderitem_currency {
  IDR
  USD
  EUR
}
